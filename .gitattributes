# Normalize line endings for all text files
* text=auto

# Force Unix line endings for source code
*.cpp    text eol=lf
*.h      text eol=lf
*.jsx    text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf

# Binary files — never mess with these
*.exe    binary
*.o      binary
*.a      binary
*.png    binary
*.jpg    binary
*.gif    binary
*.ico    binary
